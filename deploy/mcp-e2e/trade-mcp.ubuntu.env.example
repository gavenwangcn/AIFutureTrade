# 在 Ubuntu 24 上运行 trade-mcp 时，可与本目录 env.example 使用同一套下游地址。
# 示例：docker run -e DOWNSTREAM_BACKEND_BASEURL=... -e BINANCE_SERVICE_LIST='...' ...
#
# Spring 绑定（与项目 docker-compose.yml 一致）：
#   DOWNSTREAM_BACKEND_BASEURL=http://154.89.148.172:5002
#   BINANCE_SERVICE_LIST 与 trade/common/config.py 相同（单行 JSON，单引号包裹）

DOWNSTREAM_BACKEND_BASEURL=http://154.89.148.172:5002
BINANCE_SERVICE_LIST='[{"base_url":"http://185.242.232.23:5004","timeout":30},{"base_url":"http://185.242.232.42:5004","timeout":30}]'
