# 复制为 .env 后由 docker compose 加载
# cp env.example .env

# Java backend（MCP 接口）；compose 默认端口见项目 docker-compose BACKEND_PORT（常见 5002）
# 若生产环境仅开放 80 且反代到 backend，请改为实际对外根 URL（含路径前缀如有）
BACKEND_BASE_URL=http://154.89.148.172:5002

# 与 trade/common/config.py 中 BINANCE_SERVICE_LIST 完全一致（整段用单引号包起来，避免 shell/Compose 拆词）
BINANCE_SERVICE_LIST='[{"base_url":"http://185.242.232.23:5004","timeout":30},{"base_url":"http://185.242.232.42:5004","timeout":30}]'

# 可选：本机或服务器上的 trade-mcp 根 URL（例如 http://127.0.0.1:8099）
# TRADE_MCP_BASE_URL=

# E2E_HTTP_TIMEOUT_SEC=30
# E2E_SKIP_BINANCE=0
