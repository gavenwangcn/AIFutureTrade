# 复制为 .env：`cp env.example .env`
# 端到端只连 trade-mcp（MCP SSE），不直接访问 backend / binance-service。

# trade-mcp 根地址（无尾部斜杠）。本机：http://127.0.0.1:8099 ；Docker 内访问宿主机常为 http://172.17.0.1:8099 或 host 网络
TRADE_MCP_BASE_URL=http://127.0.0.1:8099

# 与 spring.ai.mcp.server.sse-endpoint 一致，默认 /sse
# MCP_SSE_PATH=/sse

# pip install -r requirements-e2e.txt 后：python mcp_e2e.py
# E2E_MCP_TIMEOUT=120
# 仅测库表 tool、跳过行情价：E2E_SKIP_MARKET=1
